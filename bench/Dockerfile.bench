FROM golang:1.24-alpine

RUN apk add --no-cache gcc musl-dev git bash python3 sqlite

WORKDIR /kai
COPY . .

RUN cd kai-cli && CGO_ENABLED=1 go build -o /usr/local/bin/kai ./cmd/kai

WORKDIR /bench
COPY bench/ .

RUN chmod +x run.sh

ENTRYPOINT ["./run.sh", "-k", "/usr/local/bin/kai", "--skip-build"]
